{
  "env": {
"ENABLE_TOOL_SEARCH": "auto:5",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "40",
    "MAX_THINKING_TOKENS": "8000",
    "DO_NOT_TRACK": "1",
    "ANTHROPIC_TELEMETRY_DISABLED": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/faizalpribadi/.claude/hooks/ctx-guard.sh"
          },
          {
            "type": "command",
            "command": "/Users/faizalpribadi/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/read-once/hook.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/faizalpribadi/.claude/hooks/filter-test-output.sh"
          },
          {
            "type": "command",
            "command": "/Users/faizalpribadi/.claude/hooks/codegraph-sync.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/faizalpribadi/.claude/hooks/session-context.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/faizalpribadi/.claude/hooks/pre-compact.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/Users/faizalpribadi/.claude/hooks/context-bar.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "claude-mem@thedotmack": true,
    "plannotator@plannotator": true,
    "ast-grep@ast-grep-marketplace": true,
    "cartographer@cartographer-marketplace": true,
    "gopls-lsp@claude-plugins-official": true,
    "mgrep@Mixedbread-Grep": true,
    "context-mode@context-mode": true
  },
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    },
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    },
    "plannotator": {
      "source": {
        "source": "github",
        "repo": "backnotprop/plannotator"
      }
    },
    "ast-grep-marketplace": {
      "source": {
        "source": "github",
        "repo": "ast-grep/agent-skill"
      }
    },
    "cartographer-marketplace": {
      "source": {
        "source": "github",
        "repo": "kingbootoshi/cartographer"
      }
    },
    "healthcare": {
      "source": {
        "source": "github",
        "repo": "anthropics/healthcare"
      }
    },
    "Mixedbread-Grep": {
      "source": {
        "source": "github",
        "repo": "mixedbread-ai/mgrep"
      }
    },
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    }
  }
}
